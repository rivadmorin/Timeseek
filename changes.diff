+    """Returns top keywords from OCR text."""
+    with cache_lock:
+        entries = list(cached_entries)
+
+    words = []
+    # Stop words (very basic list)
+    stop_words = {"the", "a", "an", "and", "or", "but", "in", "on", "at", "to", "for", "with", "is", "are", "was", "were", "of", "it", "that", "this"}
