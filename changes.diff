+        <div class="mgmt-group">
+            <div>
+                <div style="font-weight: 600;">Bulk Delete</div>
+                <div style="font-size: 13px; opacity: 0.8;">Remove snapshots within a specific time range.</div>
+            </div>
+            <form action="/bulk_delete" method="post" style="display: flex; gap: 12px; align-items: center;">
+                <select name="range" class="select-input">
+                    <option value="1">Last 1 Hour</option>
+                    <option value="24">Last 24 Hours</option>
+                    <option value="168">Last 7 Days</option>
+                </select>
+                <button type="submit" class="btn btn-secondary">Delete</button>
+            </form>
+        </div>
+
+        <div class="mgmt-group danger-group">
+            <div>
+                <div style="font-weight: 600;">Full Purge</div>
+                <div style="font-size: 13px; opacity: 0.8;">Irreversibly delete all local data.</div>
+            </div>
+            <form action="/purge" method="post" onsubmit="return confirm('Are you sure you want to delete all your data? This action is irreversible.')">
+                <button type="submit" class="btn btn-danger">Purge All</button>
+            </form>
         </div>
-        <form action="/purge" method="post" onsubmit="return confirm('Are you sure you want to delete all your data? This action is irreversible.')">
-            <button type="submit" class="purge-btn">Purge Old Data</button>
-        </form>
     </div>
 </div>
+
+<script>
+    async function loadInsights() {
+        // Load Heatmap
+        const heatmapRes = await fetch('/api/heatmap');
+        const heatmapData = await heatmapRes.json();
+        const heatmapContainer = document.getElementById('heatmap');
+
+        const now = new Date();
+        for (let i = 89; i >= 0; i--) {
+            const d = new Date();
+            d.setDate(now.getDate() - i);
+            const dateStr = d.toISOString().split('T')[0];
+            const count = heatmapData[dateStr] || 0;
+
+            const cell = document.createElement('div');
+            cell.className = 'heatmap-cell';
+            if (count > 50) cell.classList.add('level-4');
+            else if (count > 20) cell.classList.add('level-3');
+            else if (count > 5) cell.classList.add('level-2');
+            else if (count > 0) cell.classList.add('level-1');
+
+            cell.title = `${dateStr}: ${count} snapshots`;
+            heatmapContainer.appendChild(cell);
+        }
+
+        // Load Word Cloud
+        const cloudRes = await fetch('/api/wordcloud');
+        const cloudData = await cloudRes.json();
+        const cloudContainer = document.getElementById('wordcloud');
+
+        cloudData.forEach(item => {
+            const span = document.createElement('span');
+            span.textContent = item.text;
+            span.style.fontSize = `${Math.min(10 + item.size, 32)}px`;
+            span.style.opacity = Math.max(0.4, item.size / 20);
+            span.onclick = () => window.location.href = `/search?q=${item.text}`;
+            cloudContainer.appendChild(span);
+        });
+    }
+
+    loadInsights();
+</script>
 {% endblock %}
